# PostgreSQL connection string (Railway provides this as DATABASE_URL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/familytree"

# JWT secrets - use long random strings in production
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token lifetimes
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# Server
PORT=3000
CORS_ORIGIN="*"

# Gmail SMTP - used to send "forgot password" reset codes.
# GMAIL_USER is the sending Gmail address.
# GMAIL_APP_PASSWORD is a 16-character App Password (NOT your regular Gmail
# password) - generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account).
# If left unset, reset codes are logged server-side instead of emailed -
# handy for local dev.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
RESET_CODE_TTL_MINUTES=15
